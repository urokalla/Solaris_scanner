//@version=5
// Mirrors stock_scanner_sovereign/backend/breakout_logic.py `_update_minimal_cycle_state`
// (daily bar path). Labels: B*, +E9CT, E9CT*, ET9DNWF21C, E21C*, RST.
indicator("Udai Trend — Python parity", overlay=true, max_labels_count=500)

ema9Len   = input.int(9, "EMA 9 Period")
ema21Len  = input.int(21, "EMA 21 Period")
donLenIn  = input.int(10, "Donchian lookback")
rstN      = input.int(2, "Reset: consecutive closes < EMA21")

donLen = math.max(2, donLenIn)

c_B    = #2E7D32
c_E9CT = #1565C0
c_ET9  = #E65100
c_E21C = #6A1B9A
c_RST  = #C62828

ema9  = ta.ema(close, ema9Len)
ema21 = ta.ema(close, ema21Len)

// Python: don_curr = max(high[i-dlen:i]), don_prev = max(high[i-dlen-1:i-1]) on confirmed history
donCurr = ta.highest(high[1], donLen)
donPrev = ta.highest(high[2], donLen)

var int state = 0
var int bCount = 0
var int e9tCount = 0
var int e21cCount = 0
var int below21 = 0

TAG_ET9 = "ET9DNWF21C"

confirmed = barstate.isconfirmed

if confirmed
    // Same as Python: below21 consecutive closes under EMA21
    if close < ema21
        below21 := below21 + 1
    else
        below21 := 0

    // 1) RST (only thing that zeroes b/e9t/e21c counts)
    if state > 0 and below21 >= rstN
        label.new(bar_index, high, "RST", yloc=yloc.abovebar, color=c_RST, textcolor=color.white, style=label.style_label_down, size=size.small)
        state := 0
        bCount := 0
        e9tCount := 0
        e21cCount := 0
    else
        trendOk = close > ema9 and ema9 > ema21
        // Python: breakout = trend_ok and close > don_curr and prev_close <= don_prev
        isBreakout = trendOk and close > donCurr and close[1] <= donPrev

        // 2) Breakout
        if isBreakout
            state := 1
            bCount := bCount + 1
            bTxt = "B" + str.tostring(bCount)
            if low <= ema9
                bTxt := bTxt + "+E9CT"
            label.new(bar_index, low, bTxt, yloc=yloc.belowbar, color=c_B, textcolor=color.white, style=label.style_label_up, size=size.small)
        // 3) Cycle (elif state > 0 in Python — mutually exclusive with breakout on same bar)
        else if state > 0
            // A) state==1: wick below EMA9, close above EMA9
            if state == 1 and low < ema9 and close > ema9 and not isBreakout
                e9tCount := e9tCount + 1
                label.new(bar_index, low, "E9CT" + str.tostring(e9tCount), yloc=yloc.belowbar, color=c_E9CT, textcolor=color.white, style=label.style_label_up, size=size.small)
            // B) state==1: close below EMA9 → pullback tag
            else if state == 1 and close < ema9
                state := 2
                label.new(bar_index, high, TAG_ET9, yloc=yloc.abovebar, color=c_ET9, textcolor=color.white, style=label.style_label_down, size=size.small)
            // C) state==1: rare E21C — prev close < prev EMA21, this close > EMA21, close >= EMA9
            else if state == 1 and not isBreakout and close >= ema9
                if close[1] < ema21[1] and close > ema21
                    e21cCount := e21cCount + 1
                    label.new(bar_index, low, "E21C" + str.tostring(e21cCount), yloc=yloc.belowbar, color=c_E21C, textcolor=color.white, style=label.style_label_up, size=size.small)

            // D) state==2: reclaim EMA9 — E21C if close > EMA21 else E9CT
            if state == 2 and close > ema9
                state := 1
                if close > ema21
                    e21cCount := e21cCount + 1
                    label.new(bar_index, low, "E21C" + str.tostring(e21cCount), yloc=yloc.belowbar, color=c_E21C, textcolor=color.white, style=label.style_label_up, size=size.small)
                else
                    e9tCount := e9tCount + 1
                    label.new(bar_index, low, "E9CT" + str.tostring(e9tCount), yloc=yloc.belowbar, color=c_E9CT, textcolor=color.white, style=label.style_label_up, size=size.small)

plot(ema9, "EMA 9", color=color.new(c_E9CT, 40), linewidth=1)
plot(ema21, "EMA 21", color=color.new(color.black, 0), linewidth=2)
plot(donCurr, "Donchian (Python don_curr)", color=color.new(color.gray, 70), style=plot.style_stepline)

bgcolor(state == 1 ? color.new(c_B, 98) : state == 2 ? color.new(c_ET9, 98) : na)
