# Copy to .env and fill in. Never commit .env.
FYERS_CLIENT_ID=
FYERS_SECRET_KEY=
FYERS_USERNAME=
FYERS_PIN=
FYERS_TOTP_KEY=
FYERS_REDIRECT_URL=https://trade.fyers.in/api-login/redirect-uri/index.html

DB_HOST=localhost
DB_USER=fyers_user
DB_PASSWORD=change_me
DB_NAME=fyers_db
DB_PORT=5432
DATABASE_URL=postgresql://fyers_user:change_me@localhost:5432/fyers_db

# Optional: websocket / paths
# FYERS_WS_LITEMODE=false
# PIPELINE_DATA_DIR=/app/data/historical

# fyers_data_pipeline `main.py` (Docker service `pipeline`): IST schedule
# EOD_SYNC_IST_HOUR=15
# EOD_SYNC_IST_MINUTE=45
# BACKFILL_IST_HOUR=1
# BACKFILL_IST_MINUTE=0

# Token management: MANUAL. Each morning, generate a fresh Fyers JWT (use
# stock_scanner_sovereign/manual_token.py or the Fyers dashboard) and overwrite
# stock_scanner_sovereign/access_token.txt. The pipeline service detects expiry
# and retries automatically once the file mtime changes.
# EOD_TOKEN_RETRY_MINUTES=60   # back-off between EOD retries while token is bad

# Daily EOD gap-heal window (0 = disable, default 30 days)
# EOD_HEAL_DAYS=30
# EOD pacing: 1.0s gap across ~2200 symbols is ~40m (+gap-heal overhead)
# EOD_SYNC_PER_SYMBOL_GAP_SECONDS=1.0
# EOD_SYNC_HEAL_GAP_SECONDS=0.5

# Docker defaults (see docker-compose.yml): master scanner runs the main RS grid; sidecar analyzer is
# OFF (SIDECAR_RUN_ANALYZER=0) so there is no BRK/EMA30/breakout loop — BRK column may show "—" or stale DB values.
# Re-enable full sidecar: set SIDECAR_RUN_ANALYZER=1 on the sidecar service in compose.
#
# SIDECAR_RUN_ANALYZER=1
# SIDECAR_RVCR_ENABLED=1
# SIDECAR_UDAI_PINE=1
# SIDECAR_M_RSI2=1
# SIDECAR_PRE_THRUST_ENABLED=1
# SIDECAR_STAGE1_BOX_ENABLED=1
# MRS_RCVR_COMPUTE_ENABLED=1   # master scanner weekly recovery / Below0↑
# CANSLIM_ENABLED=1            # master scanner CANSLIM vectors + 6-score merge (default on without compose)
# NSE 15:30 IST display / weekly stamps (see CYCLE_SAME_DAY_BAR_FRIDAY_EOD_* in settings.py)
# STRUCTURAL_SAMEDAY_AFTER_EOD_ENABLED=0   # 1=default: Mon–Fri after cutoff, LAST TAG D uses today’s closed bar same evening
# STRUCTURAL_SAMEDAY_AFTER_EOD_IST_HOUR=16
# STRUCTURAL_SAMEDAY_AFTER_EOD_IST_MINUTE=15
# BREAKOUT_TIMING_EOD_PARQUET_REFRESH_ENABLED=0   # 1=default: timing+daily clock, first poll after 16:30 IST reloads parquet into buffers once/day
# BREAKOUT_TIMING_EOD_PARQUET_REFRESH_IST_HOUR=16
# BREAKOUT_TIMING_EOD_PARQUET_REFRESH_IST_MINUTE=30
# Reflex UI (Docker dashboard): browser WebSocket target — same host as the UI, port 8000 (default localhost).
# API_URL=http://localhost:8000
